# ============================================================
# ENVIRONMENT VARIABLES — Copy to .env and fill in your values
# ============================================================

# MiniMax (or compatible OpenAI-format) API key
MINIMAX_API_KEY=your_api_key_here

# API base URL (MiniMax or any OpenAI-compatible endpoint)
API_BASE_URL=https://api.minimax.io/v1

# Model to use
MODEL=MiniMax-M2.7
